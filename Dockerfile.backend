# Dockerfile.backend
FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY agents/    agents/
COPY api/       api/
COPY config/    config/
COPY swarm/     swarm/
COPY workflows/ workflows/
COPY main.py    .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
