      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), format('{0}-backend', variables('prefix')), '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
