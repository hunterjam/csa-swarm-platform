        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "12383860818786273030"
            }
          },
          "parameters": {
            "environmentId": {
              "type": "string",
              "metadata": {
                "description": "Container Apps Environment resource ID"
              }
            },
            "appName": {
              "type": "string",
              "metadata": {
                "description": "Container app name"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Location"
              }
            },
            "image": {
              "type": "string",
              "metadata": {
                "description": "Container image (registry/image:tag)"
              }
            },
            "targetPort": {
              "type": "int",
              "metadata": {
                "description": "Target port exposed by the container"
              }
            },
            "registryServer": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "ACR login server for managed-identity pull (e.g. myacr.azurecr.io)"
              }
            },
            "env": {
              "type": "array",
              "defaultValue": [],
              "metadata": {
                "description": "Environment variables"
              }
            },
            "cpu": {
              "type": "string",
              "defaultValue": "0.5",
              "metadata": {
                "description": "CPU cores (0.5, 1, 2)"
              }
            },
            "memory": {
              "type": "string",
              "defaultValue": "1Gi",
              "metadata": {
                "description": "Memory (1Gi, 2Gi)"
              }
            },
            "minReplicas": {
              "type": "int",
              "defaultValue": 1,
              "metadata": {
                "description": "Minimum replicas"
              }
            },
            "maxReplicas": {
              "type": "int",
              "defaultValue": 5,
              "metadata": {
                "description": "Maximum replicas"
              }
            },
            "azdServiceName": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "azd service name tag (used by azd deploy to locate this app)"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[parameters('appName')]",
              "location": "[parameters('location')]",
              "tags": "[if(empty(parameters('azdServiceName')), createObject(), createObject('azd-service-name', parameters('azdServiceName')))]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "environmentId": "[parameters('environmentId')]",
                "configuration": {
                  "registries": "[if(empty(parameters('registryServer')), createArray(), createArray(createObject('server', parameters('registryServer'), 'identity', 'system')))]",
                  "ingress": {
                    "external": true,
                    "targetPort": "[parameters('targetPort')]",
                    "transport": "auto"
                  }
                },
                "template": {
                  "containers": [
                    {
                      "name": "[parameters('appName')]",
                      "image": "[parameters('image')]",
                      "resources": {
                        "cpu": "[json(parameters('cpu'))]",
                        "memory": "[parameters('memory')]"
                      },
                      "env": "[parameters('env')]"
                    }
                  ],
                  "scale": {
                    "minReplicas": "[parameters('minReplicas')]",
                    "maxReplicas": "[parameters('maxReplicas')]",
                    "rules": [
                      {
                        "name": "http-scale",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "10"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "outputs": {
            "principalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01', 'full').identity.principalId]"
            },
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn]"
            }
          }
        }
      },
      "dependsOn": [
