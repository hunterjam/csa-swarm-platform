              "adminConsentDisplayName": "[format('Access {0}-webapp', variables('prefix'))]",
              "userConsentDescription": "[format('Allow the app to access {0}-webapp on your behalf.', variables('prefix'))]",
              "userConsentDisplayName": "[format('Access {0}-webapp', variables('prefix'))]",
