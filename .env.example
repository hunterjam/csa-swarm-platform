# ── Azure OpenAI (via AI Foundry) ───────────────────────────────────────
# Required. Azure OpenAI endpoint exposed by your AI Foundry / AI Services account.
# AI Foundry portal → your project → Overview → "Azure OpenAI endpoint"
FOUNDRY_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com

# Optional. Foundry project endpoint (kept for reference / future tooling).
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project-name>

# Model deployment name (must match the deployment created in Azure AI Foundry).
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# ── Azure Cosmos DB ─────────────────────────────────────────────────────
# Required.
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=csa_swarm
COSMOS_CONTAINER=swarm
# Leave blank when using DefaultAzureCredential / Managed Identity (recommended).
COSMOS_KEY=

# ── Entra ID (MSAL Auth) ────────────────────────────────────────────────
# Required when AUTH_ENABLED=true.
ENTRA_TENANT_ID=<your-aad-tenant-id>
ENTRA_CLIENT_ID=<app-registration-client-id>

# ── API server ──────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the FastAPI backend.
CORS_ORIGINS=http://localhost:3000

# ── App behaviour ───────────────────────────────────────────────────────
# Set to "false" to disable JWT validation for local single-user dev.
AUTH_ENABLED=false
# Maximum debate rounds per session.
MAX_DEBATE_ROUNDS=5
